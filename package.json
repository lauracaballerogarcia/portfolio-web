{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Digital Product Design portfolio — technology, people and environment",
  "author": "Laura Caballero",
  "license": "ISC",
  "browserslist": [
    "> 0.2%",
    "not dead",
    "last 10 years"
  ],
  "scripts": {
    "start": "npm-run-all clean parcel:dev",
    "build": "npm-run-all clean parcel:build",
    "parcel:dev": "parcel src/pages/index.html src/pages/project/index.html src/pages/about/index.html",
    "parcel:build": "parcel build src/pages/index.html src/pages/project/index.html src/pages/about/index.html",
    "clean": "rimraf dist .parcel-cache",
    "deploy": "npm run parcel:build && wrangler deploy",
    "preview": "npm run parcel:build && wrangler dev"
  },
  "devDependencies": {
    "@parcel/transformer-inline-string": "^2.16.4",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.16.4",
    "posthtml-include": "^2.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.33.5",
    "wrangler": "^4.106.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "gsap": "^3.14.2",
    "marked": "^18.0.5"
  }
}
